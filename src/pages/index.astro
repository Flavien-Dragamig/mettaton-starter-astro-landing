---
const features = [
  {
    icon: "⚡",
    title: "Ultra rapide",
    body: "Zéro JavaScript par défaut. Astro livre du HTML statique pour des pages qui se chargent instantanément.",
  },
  {
    icon: "🧩",
    title: "Composable",
    body: "Assemblez votre stack avec des composants Astro, React, Vue ou Svelte selon vos besoins.",
  },
  {
    icon: "🚀",
    title: "Prêt à déployer",
    body: "Build optimisé en une commande, déployable sur n'importe quel hébergeur statique ou edge.",
  },
];

const title = "Mettaton Starter — Astro Landing";
const description =
  "Un starter de landing page marketing prêt à l'emploi, construit avec Astro. Hero, features, CTA et footer inclus.";
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Mettaton</a>
      <nav class="nav">
        <a href="#features">Fonctionnalités</a>
        <a href="#cta">Commencer</a>
      </nav>
    </header>

    <main>
      <!-- HERO -->
      <section class="hero">
        <div class="hero-inner">
          <span class="eyebrow">Starter Astro · Landing Page</span>
          <h1>Lancez votre page d'atterrissage en quelques minutes</h1>
          <p class="subtitle">
            Un modèle de landing page moderne, rapide et accessible. Personnalisez
            le contenu, déployez, et concentrez-vous sur ce qui compte&nbsp;: votre produit.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#cta">Démarrer maintenant</a>
            <a class="btn btn-ghost" href="#features">Découvrir</a>
          </div>
        </div>
      </section>

      <!-- FEATURES -->
      <section id="features" class="features">
        <h2 class="section-title">Pourquoi ce starter&nbsp;?</h2>
        <p class="section-lead">Tout ce qu'il faut pour une landing page performante, rien de superflu.</p>
        <div class="grid">
          {
            features.map((f) => (
              <article class="card">
                <div class="card-icon" aria-hidden="true">{f.icon}</div>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- CTA FINALE -->
      <section id="cta" class="cta">
        <div class="cta-inner">
          <h2>Prêt à construire votre prochaine landing&nbsp;?</h2>
          <p>Clonez ce starter, adaptez le contenu et publiez en un clin d'œil.</p>
          <a class="btn btn-primary btn-lg" href="https://astro.build" target="_blank" rel="noopener">
            Construire avec Astro
          </a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} Mettaton Starter. Construit avec Astro.</p>
      <nav class="footer-nav">
        <a href="#features">Fonctionnalités</a>
        <a href="#cta">Commencer</a>
        <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
      </nav>
    </footer>

    <style is:global>
      :root {
        --bg: #0b0d17;
        --surface: #151826;
        --text: #e7e9f3;
        --muted: #9aa0b4;
        --accent: #7c5cff;
        --accent-2: #22d3ee;
        --border: #242838;
        --max: 1100px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3 { line-height: 1.15; margin: 0; }
    </style>

    <style>
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: var(--max);
        margin: 0 auto;
        padding: 1.25rem 1.5rem;
      }
      .brand {
        font-weight: 800;
        font-size: 1.25rem;
        letter-spacing: -0.02em;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .nav a { color: var(--muted); margin-left: 1.5rem; font-size: 0.95rem; transition: color 0.2s; }
      .nav a:hover { color: var(--text); }

      .hero {
        text-align: center;
        padding: 5rem 1.5rem 4rem;
        background:
          radial-gradient(60% 60% at 50% 0%, rgba(124, 92, 255, 0.18), transparent 70%),
          radial-gradient(40% 40% at 80% 10%, rgba(34, 211, 238, 0.12), transparent 70%);
      }
      .hero-inner { max-width: 760px; margin: 0 auto; }
      .eyebrow {
        display: inline-block;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent-2);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.35rem 0.9rem;
        margin-bottom: 1.5rem;
      }
      .hero h1 {
        font-size: clamp(2.2rem, 5vw, 3.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        margin-bottom: 1.25rem;
      }
      .subtitle { color: var(--muted); font-size: 1.15rem; margin: 0 auto 2rem; max-width: 620px; }
      .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

      .btn {
        display: inline-block;
        padding: 0.8rem 1.6rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 1rem;
        transition: transform 0.15s ease, opacity 0.2s ease, background 0.2s ease;
      }
      .btn:hover { transform: translateY(-2px); }
      .btn-primary {
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
        color: #0b0d17;
      }
      .btn-primary:hover { opacity: 0.92; }
      .btn-ghost { border: 1px solid var(--border); color: var(--text); }
      .btn-ghost:hover { background: var(--surface); }
      .btn-lg { padding: 1rem 2rem; font-size: 1.1rem; }

      .features { max-width: var(--max); margin: 0 auto; padding: 5rem 1.5rem; text-align: center; }
      .section-title { font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 800; letter-spacing: -0.02em; }
      .section-lead { color: var(--muted); margin: 0.75rem auto 3rem; max-width: 520px; }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
        text-align: left;
      }
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 2rem;
        transition: transform 0.2s ease, border-color 0.2s ease;
      }
      .card:hover { transform: translateY(-4px); border-color: var(--accent); }
      .card-icon { font-size: 2rem; margin-bottom: 1rem; }
      .card h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
      .card p { color: var(--muted); margin: 0; }

      .cta { padding: 1rem 1.5rem 6rem; }
      .cta-inner {
        max-width: var(--max);
        margin: 0 auto;
        text-align: center;
        background: linear-gradient(135deg, rgba(124, 92, 255, 0.15), rgba(34, 211, 238, 0.1));
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: 4rem 2rem;
      }
      .cta-inner h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); font-weight: 800; letter-spacing: -0.02em; }
      .cta-inner p { color: var(--muted); margin: 1rem auto 2rem; max-width: 480px; }

      .site-footer {
        max-width: var(--max);
        margin: 0 auto;
        padding: 2rem 1.5rem 3rem;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        color: var(--muted);
        font-size: 0.9rem;
      }
      .footer-nav a { margin-left: 1.5rem; transition: color 0.2s; }
      .footer-nav a:first-child { margin-left: 0; }
      .footer-nav a:hover { color: var(--text); }
    </style>
  </body>
</html>
